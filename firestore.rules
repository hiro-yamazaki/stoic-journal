rules_version = '2';

// Stoic Journal セキュリティルール
// 方針:
//  - 未ログインユーザーは一切アクセス不可（request.auth != null）
//  - 各ユーザーは自分(userId)のジャーナルだけ読み書き可能
//  - 対話(dialogue)は、親ジャーナルの所有者だけ読み書き可能
// → apiKey が公開されても、他人のデータは閲覧・改変できない。
service cloud.firestore {
  match /databases/{database}/documents {

    match /journals/{id} {
      allow read:           if request.auth != null && request.auth.uid == resource.data.userId;
      allow create:         if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;

      // 自分との対話（書き出し＋コメント）
      match /dialogue/{msgId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/journals/$(id)).data.userId == request.auth.uid;
      }
    }
  }
}
